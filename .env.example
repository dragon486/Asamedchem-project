# Example environment variables - copy to .env and fill in real values

# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection details → Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-random-32-char-secret-here"

# App URL - use your actual domain in production
NEXTAUTH_URL="http://localhost:3001"
